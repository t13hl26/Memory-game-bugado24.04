--- !u!114 &1889234763
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1889234762}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6ba4e708e2481c44fabe6b3583598138, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 250732418}
  characterNameText: {fileID: 510503811}
  dialogueText: {fileID: 572383335}
  characterImageLeft: {fileID: 0}
  characterImageRight: {fileID: 0}
  continueText: {fileID: 474288416}
  introSequence:
    sequenceName: "Introdu\xE7\xE3o"
    lines:
    - characterName: "J\xFAlia"
      text: "Primeiro dia de est\xE1gio na Secretaria do Meio Ambiente... Estou animada
        para come\xE7ar!"
      characterSprite: {fileID: 0}
      isLeft: 0
    - characterName: Sato
      text: "J\xFAlia, temos um problema grave. O Bar\xE3o do Descarte invadiu nosso
        sistema e corrompeu todos os dados sobre o Rio Tiet\xEA."
      characterSprite: {fileID: 0}
      isLeft: 1
    - characterName: Sato
      text: "Voc\xEA precisa reorganizar as evid\xEAncias. \xC9 a \xFAnica forma
        de realizar as fiscaliza\xE7\xF5es e salvar o rio!"
      characterSprite: {fileID: 0}
      isLeft: 1
  phase1StartSequence:
    sequenceName: "Fase 1 - Sales\xF3polis"
    lines:
    - characterName: Sato
      text: "J\xFAlia, recebemos um arquivo corrompido com dados sobre o Rio Tiet\xEA.
        O Bar\xE3o do Descarte sabotou nosso sistema!"
      characterSprite: {fileID: 0}
      isLeft: 1
    - characterName: "J\xFAlia"
      text: " Entendido, Sato! Vou reorganizar as evid\xEAncias. Come\xE7o pela nascente
        em Sales\xF3polis."
      characterSprite: {fileID: 0}
      isLeft: 0
  phase2StartSequence:
    sequenceName: Fase 2 - Zona Rural
    lines:
    - characterName: Sato
      text: "A \xE1gua j\xE1 est\xE1 mudando de cor, J\xFAlia. Vejo pneus e garrafas
        nas margens. A situa\xE7\xE3o est\xE1 piorando."
      characterSprite: {fileID: 0}
      isLeft: 1
    - characterName: "J\xFAlia"
      text: "Vou identificar e registrar tudo! Cada res\xEDduo removido \xE9 uma
        vit\xF3ria para o rio."
      characterSprite: {fileID: 0}
      isLeft: 0
  phase3StartSequence:
    sequenceName: 
    lines:
    - characterName: Sato
      text: "Chegamos \xE0 Grande S\xE3o Paulo. O Bar\xE3o do Descarte est\xE1 aqui.
        Este \xE9 o desafio final, J\xFAlia!"
      characterSprite: {fileID: 0}
      isLeft: 1
    - characterName: "Doutora Res\xEDduo"
      text: "Haha! Voc\xEAs nunca v\xE3o restaurar esse arquivo. Eu me encarrego
        de atrapalhar cada passo!"
      characterSprite: {fileID: 0}
      isLeft: 0
    - characterName: "J\xFAlia"
      text: "N\xE3o vou deixar! O Rio Tiet\xEA vai ser limpo e o Bar\xE3o vai responder
        por tudo!"
      characterSprite: {fileID: 0}
      isLeft: 1
  endingSequence:
    sequenceName: Final
    lines:
    - characterName: Sato
      text: "Incr\xEDvel, J\xFAlia! O arquivo foi totalmente restaurado. O Bar\xE3o
        do Descarte ser\xE1 multado e obrigado a recuperar as margens do rio!"
      characterSprite: {fileID: 0}
      isLeft: 1
    - characterName: "J\xFAlia"
      text: "O Rio Tiet\xEA vai ser limpo novamente! Valeu a pena cada evid\xEAncia
        encontrada. Somos Guardi\xF5es das \xC1guas!"
      characterSprite: {fileID: 0}
      isLeft: 0
  typingSpeed: 40
