MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1036396544}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6ba4e708e2481c44fabe6b3583598138, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 0}
  characterNameText: {fileID: 0}
  dialogueText: {fileID: 0}
  characterImageLeft: {fileID: 0}
  characterImageRight: {fileID: 0}
  continueText: {fileID: 0}
  introSequence:
    sequenceName: "Introdu\xE7\xE3o"
    lines:
    - characterName: Sato
      text: "J\xFAlia, recebemos um arquivo corrompido sobre o Rio Tiet\xEA. Precisamos
        restaurar as evid\xEAncias."
      characterSprite: {fileID: 0}
      isLeft: 1
    - characterName: "J\xFAlia"
      text: Entendido! Vou organizar tudo, pode deixar.
      characterSprite: {fileID: 0}
      isLeft: 0
  phase1StartSequence:
    sequenceName: 
    lines:
    - characterName: Sato
      text: "Estamos em Sales\xF3polis, onde o rio nasce. A fauna est\xE1 amea\xE7ada.
        Identifique os pares!"
      characterSprite: {fileID: 0}
      isLeft: 0
  phase2StartSequence:
    sequenceName: 
    lines:
    - characterName: "J\xFAlia"
      text: "A \xE1gua j\xE1 est\xE1 ficando marrom... Que descaso com o rio."
      characterSprite: {fileID: 0}
      isLeft: 0
  phase3StartSequence:
    sequenceName: 
    lines:
    - characterName: "Bar\xE3o do Descarte"
      text: "Voc\xEAs nunca v\xE3o me parar. O progresso n\xE3o espera!"
      characterSprite: {fileID: 0}
      isLeft: 0
  endingSequence:
    sequenceName: 
    lines:
    - characterName: Sato
      text: "Miss\xE3o cumprida, J\xFAlia. Voc\xEA \xE9 a Guardi\xE3 das \xC1guas!"
      characterSprite: {fileID: 0}
      isLeft: 0
  typingSpeed: 40
